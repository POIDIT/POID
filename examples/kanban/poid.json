{
  "poid": "1.0",
  "type": "app",
  "app": {
    "id": "dev.poid.kanban",
    "name": "Kanban",
    "version": "1.0.0",
    "author": "POID",
    "description": "A kanban board that stores its cards in poid.db.docs.",
    "license": "MIT"
