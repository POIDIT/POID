{
  "name": "@poid/studio",
  "version": "0.0.1",
  "private": true,
  "description": "POID Studio - the one executable (Tauri v2): Reader windows and the Studio hub.",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:ui": "node scripts/build-ui.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "tauri": "tauri"
  },
  "dependencies": {
    "@poid/host": "workspace:*",
    "@poid/sdk": "workspace:*",
    "@poid/ui": "workspace:*",
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-dialog": "^2.2.0",
    "wa-sqlite": "1.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.5.0",
    "esbuild": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
